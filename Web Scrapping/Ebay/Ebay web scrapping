from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC
import csv
import os

url = "https://www.ebay.com/b/Cell-Phones-Smartphones/9355/bn_320094"

# Launch Chrome browser automatically
driver = webdriver.Chrome()
driver.get(url)

# Set explicit wait up to 15 seconds for elements to load
wait = WebDriverWait(driver, 15)

# Wait until all anchor tags containing images are present on the page
cards = wait.until(
    EC.presence_of_all_elements_located((By.XPATH, "//a[.//img]"))
)

categories = []
seen_urls = set()  # Track visited URLs to avoid duplicate products

for card in cards:
    category = {}

    # Get the href link of each product card
    card_url = card.get_attribute("href")

    # Skip if URL is empty or already processed
    if not card_url or card_url in seen_urls:
        continue

    category["url"] = card_url

    try:
        # Extract image source and alt text as category name
        img = card.find_element(By.TAG_NAME, "img")
        category["img"] = img.get_attribute("src")
        category["category_name"] = img.get_attribute("alt")
    except:
        # Set empty values if image elements are not found
        category["img"] = ""
        category["category_name"] = ""

    try:
        # Get immediate parent div for structural metadata
        parent_div = card.find_element(By.XPATH, "./ancestor::div[1]")
        category["div_id"] = parent_div.get_attribute("id")
        category["div_class"] = parent_div.get_attribute("class")
    except:
        # Set empty values if parent div is not found
        category["div_id"] = ""
        category["div_class"] = ""

    # Skip cards with no category name
    if not category["category_name"]:
        continue

    # Mark URL as seen and save the product
    seen_urls.add(card_url)
    categories.append(category)

# Close the browser after scraping
driver.quit()

# Create output folder if it does not exist
os.makedirs("Week6", exist_ok=True)
filename = "Week6/ebayproducts.csv"

# Write all unique categories to CSV file
with open(filename, "w", newline="", encoding="utf-8") as f:
    w = csv.DictWriter(
        f,
        fieldnames=["category_name", "url", "img", "div_id", "div_class", "price"]
    )
    w.writeheader()
    for c in categories:
        # Price field is empty as eBay shows price on product detail page
        c["price"] = ""
        w.writerow(c)

print(f"Saved {len(categories)} unique categories to {filename}")